#!/usr/bin/env bash
# Bash completion for phpsoftbox command
# Usage: source /path/to/_phpsoftbox_completion

_phpsoftbox_pick_exec() {
    local candidate
    for candidate in "$@"; do
        if [[ -n "$candidate" && -x "$candidate" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

_phpsoftbox_pick_file() {
    local candidate
    for candidate in "$@"; do
        if [[ -n "$candidate" && -f "$candidate" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

_phpsoftbox_completion() {
    local line_before="${COMP_LINE:0:COMP_POINT}"
    local ends_with_space=0
    local cur="${line_before##*[[:space:]]}"

    [[ "$line_before" =~ [[:space:]]$ ]] && ends_with_space=1

    local -a tokens
    read -r -a tokens <<< "$line_before"
    [[ ${#tokens[@]} -eq 0 ]] && return 0

    local cmd_word_index=1
    if [[ "${tokens[0]}" == "php" ]]; then
        cmd_word_index=2
    fi

    local token_index=$(( ${#tokens[@]} - 1 ))
    local completing_command=0
    if [[ $ends_with_space -eq 1 ]]; then
        if [[ $token_index -eq $((cmd_word_index - 1)) ]]; then
            completing_command=1
            cur=""
        fi
    else
        if [[ $token_index -eq $cmd_word_index ]]; then
            completing_command=1
        fi
    fi

    [[ $completing_command -ne 1 ]] && return 0

    local phpsoftbox_cmd=()
    if [[ "${tokens[0]}" == "php" ]]; then
        local target="${tokens[1]:-}"
        [[ -z "$target" ]] && return 0
        [[ "$(basename -- "$target")" != "phpsoftbox" ]] && return 0

        local phpsoftbox_file
        phpsoftbox_file="$(_phpsoftbox_pick_file "$target" "./$target")"
        if [[ -z "$phpsoftbox_file" ]]; then
            if [[ "$target" == */* || "$target" == ./* || "$target" == ../* ]]; then
                return 0
            fi
            if command -v phpsoftbox >/dev/null 2>&1; then
                phpsoftbox_file="phpsoftbox"
            else
                phpsoftbox_file="$(_phpsoftbox_pick_file ./vendor/bin/phpsoftbox vendor/bin/phpsoftbox ./bin/phpsoftbox)"
            fi
        fi

        [[ -z "$phpsoftbox_file" ]] && return 0
        phpsoftbox_cmd=(php "$phpsoftbox_file")
    else
        local first="${tokens[0]:-}"
        local phpsoftbox_bin
        phpsoftbox_bin="$(_phpsoftbox_pick_exec "$first" "./$first" ./vendor/bin/phpsoftbox vendor/bin/phpsoftbox ./bin/phpsoftbox)"
        if [[ -z "$phpsoftbox_bin" ]]; then
            command -v phpsoftbox >/dev/null 2>&1 && phpsoftbox_bin="phpsoftbox"
        fi

        [[ -z "$phpsoftbox_bin" ]] && return 0
        phpsoftbox_cmd=("$phpsoftbox_bin")
    fi

    local commands
    commands="$("${phpsoftbox_cmd[@]}" list 2>/dev/null | awk '/^- / {print $2}')"

    local colon_break=0
    [[ "$COMP_WORDBREAKS" == *:* ]] && colon_break=1

    local prefix=""
    if [[ $colon_break -eq 1 && "$cur" == *:* ]]; then
        prefix="${cur%:*}:"
    fi

    local -a replies=()
    local cmd
    while IFS= read -r cmd; do
        [[ -z "$cmd" ]] && continue
        [[ -z "$cur" || "$cmd" == "$cur"* ]] || continue
        if [[ -n "$prefix" ]]; then
            replies+=("${cmd#"$prefix"}")
        else
            replies+=("$cmd")
        fi
    done <<< "$commands"

    COMPREPLY=("${replies[@]}")
}

complete -o bashdefault -o default -o nospace -F _phpsoftbox_completion phpsoftbox
complete -o bashdefault -o default -o nospace -F _phpsoftbox_completion psb
complete -o bashdefault -o default -o nospace -F _phpsoftbox_completion ./vendor/bin/phpsoftbox
complete -o bashdefault -o default -o nospace -F _phpsoftbox_completion vendor/bin/phpsoftbox
complete -o bashdefault -o default -o nospace -F _phpsoftbox_completion ./bin/phpsoftbox
complete -o bashdefault -o default -o nospace -F _phpsoftbox_completion php
