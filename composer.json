{
    "name": "phpsoftbox/installer",
    "description": "Installer and launcher for PhpSoftBox Workspace projects",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Anton K.",
            "email": "inspector-who@mail.ru"
        }
    ],
    "require": {
        "php": "^8.4",
        "phpsoftbox/cli-app": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "PhpSoftBox\\Installer\\": "src/"
        }
    },
    "bin": [
        "bin/phpsoftbox"
    ],
    "scripts": {
        "test": "phpunit",
        "cs:fix": "vendor/bin/psb-cs-fixer fix",
        "cs:check": "vendor/bin/psb-cs-fixer check --diff"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
